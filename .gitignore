# Compound System - Git Ignore

# Environment variables (contains API keys)
.env

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Temporary files
*.tmp
*.temp
*.log

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Node modules (if using any JS tools)
node_modules/

# Archives (generated by refresh.sh)
.archive/

# Checkpoints (may contain sensitive context)
.checkpoints/

# Platform-specific generated files (regenerate with init-platform.sh)
.cursor/
.github/
.aider.conf.yml
CLAUDE-compound.md
CONVENTIONS-compound.md
hooks-claude-code.json
