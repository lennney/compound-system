# Compound System - LLM API Configuration
# Copy this file to .env and fill in your API key
#
# Run setup wizard for interactive configuration:
#   bash scripts/setup.sh
#
# Or manually configure:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env and add your API key
#   3. Test connection: bash scripts/setup.sh --test

# ===========================================
# Required: API Key
# ===========================================
LLM_API_KEY=your-api-key-here

# ===========================================
# Optional: Custom Endpoint and Model
# ===========================================
# If not set, uses provider defaults
# LLM_ENDPOINT=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ===========================================
# Supported Providers
# ===========================================
#
# DeepSeek (default):
#   LLM_ENDPOINT=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# OpenAI:
#   LLM_ENDPOINT=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#
# 小米 MIMO (Token Plan):
#   LLM_ENDPOINT=https://token-plan-cn.xiaomimimo.com/v1
#   LLM_MODEL=mimo-v2.5
#
# 小米 MIMO (SK):
#   LLM_ENDPOINT=https://api.xiaomimimo.com/v1
#   LLM_MODEL=mimo-v2.5
#
# Anthropic:
#   LLM_ENDPOINT=https://api.anthropic.com/v1
#   LLM_MODEL=claude-3-haiku-20240307
#
# Custom OpenAI-compatible API:
#   LLM_ENDPOINT=https://your-api.com/v1
#   LLM_MODEL=your-model-name

# ===========================================
# Optional: Advanced Settings
# ===========================================
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=2000
